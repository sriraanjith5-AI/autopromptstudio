# =============================================================================
# AutoPrompt Studio — .gitignore
# Python (FastAPI / DSPy) + Node.js (React) + general development
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
lib/
lib64/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
coverage/
htmlcov/
nosetests.xml
pytest.ini.bak

# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Node.js / React
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp/
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Build output
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/

# TypeScript
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment & secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env
secrets/
credentials/
*.key
*.pem
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Databases & local data
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal
data/
local_data/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*

# -----------------------------------------------------------------------------
# OS generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# DSPy / ML artefacts
# -----------------------------------------------------------------------------
*.pkl
*.pickle
*.pt
*.pth
*.onnx
*.bin
model_cache/
dspy_cache/
.cache/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.hypothesis/
